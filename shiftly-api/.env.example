APP_ENV=prod
APP_SECRET=remplacer_par_openssl_rand_hex_32

# Railway injecte cette variable automatiquement via le plugin MySQL
# Format : mysql://user:password@host:3306/dbname?serverVersion=8.0&charset=utf8mb4
DATABASE_URL="mysql://user:password@host:3306/dbname?serverVersion=8.0&charset=utf8mb4"

# CORS — regex de l'URL frontend (origin_regex: true dans nelmio_cors.yaml)
# Prod ex : ^https://shiftly\.vercel\.app$
# Dev (.env local) : ^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$
CORS_ALLOW_ORIGIN=^https://votre-frontend\.vercel\.app$

# JWT — chemins vers les clés (gérées via entrypoint.sh au démarrage)
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=remplacer_par_la_passphrase_locale

# Clés JWT encodées en base64 (pour Railway)
# Générer : base64 -i config/jwt/private.pem | tr -d '\n'
JWT_SECRET_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=


# Sentry — monitoring des erreurs
SENTRY_DSN=https://your-dsn@sentry.io/your-project-id
SENTRY_AUTH_TOKEN=changeme
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=shiftly-api
